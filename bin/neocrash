#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"

# Resolve NEOCRASH_DIR: env var > script location
if [ -z "${NEOCRASH_DIR:-}" ]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    NEOCRASH_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
fi
export NEOCRASH_DIR

LIB_DIR="$NEOCRASH_DIR/lib"

. "$LIB_DIR/config.sh"
. "$LIB_DIR/core.sh"
. "$LIB_DIR/profile.sh"
. "$LIB_DIR/cron.sh"
. "$LIB_DIR/geodata.sh"

# Ensure runtime dirs and config exist
mkdir -p "$NEOCRASH_DIR/profiles"
[ -f "$NEOCRASH_DIR/neocrash.conf" ] || touch "$NEOCRASH_DIR/neocrash.conf"
getconfig

RULES_FILE="$NEOCRASH_DIR/rules.txt"

_validate_port() {
    local port="$1"
    [[ "$port" =~ ^[0-9]+$ ]] && [ "$port" -ge 1 ] && [ "$port" -le 65535 ]
}

usage() {
    cat <<'EOF'
neocrash — proxy core manager for mihomo / sing-box

Usage: neocrash <command> [args]

Service:
  start                         Start the proxy core
  stop                          Stop the proxy core
  restart                       Restart the proxy core
  status                        Show core status

Profiles:
  profile list                  List all profiles
  profile add <name> <url>      Add a profile from subscription URL
  profile import <name> <path>  Import a local config file
  profile remove <name>         Remove a profile
  profile switch <name>         Switch to a profile
  profile update [name]         Re-download profile (default: active)
  profile update-all            Update all profiles

Rules:
  rule add <rule>               Add a custom routing rule
  rule remove <number>          Remove a rule by line number
  rule list                     List all custom rules

  Rule format (mihomo-style, comma-separated):
    DOMAIN,example.com,DIRECT
    DOMAIN-SUFFIX,google.com,Proxy
    DOMAIN-KEYWORD,ads,REJECT
    IP-CIDR,192.168.0.0/16,DIRECT
    GEOIP,CN,DIRECT
    GEOSITE,category-ads,REJECT

Geodata:
  geodata list                  List installed geodata files
  geodata available             Show downloadable geodata files
  geodata update <name>         Download/update a geodata file
  geodata update-all            Download all geodata for current core
  geodata remove <name>         Remove a geodata file
  geodata import <path>         Import a local geodata file

Settings:
  set <key> <value>             Set a config value (see keys below)
  config show                   Show current config

  Network keys:
    mix_port      Mixed (HTTP+SOCKS) port        (default: 7890)
    socks_port    SOCKS5 port                     (default: 7891)
    redir_port    Transparent proxy port          (default: 7892)
    api_port      API/dashboard port              (default: 9090)
    dns_port      DNS listen port                 (default: 1053)
    bind_address  Listen address                  (default: 127.0.0.1)

  Core keys:
    core_type     mihomo | singbox                (default: mihomo)
    log_level     silent|error|warning|info|debug (default: info)

  TUN keys:
    tun_mode      on | off                        (default: off)
    tun_stack     system | gvisor | mixed          (default: mixed)
    tun_device    TUN interface name               (default: utun)
    tun_mtu       MTU size                         (default: 9000)
    tun_auto_route    true | false                 (default: true)
    tun_auto_detect   true | false                 (default: true)
    tun_dns_hijack    DNS hijack target             (default: any:53)
    tun_inet4     TUN IPv4 CIDR                    (default: 172.19.0.1/30)
    tun_inet6     TUN IPv6 CIDR                    (default: fdfe:dcba:9876::1/126)

  Cron:
    cron          Cron schedule | off              (default: off)

  version                       Show version
  -h, --help                    Show this help

Examples:
  neocrash profile add work https://example.com/sub
  neocrash profile import local /path/to/config.yaml
  neocrash profile switch work
  neocrash start
  neocrash set mix_port 7891
  neocrash set log_level debug
  neocrash set tun_mode on
  neocrash rule add "DOMAIN-SUFFIX,example.com,DIRECT"
  neocrash geodata update geoip.dat
  neocrash geodata update-all
  neocrash set cron "0 */6 * * *"
EOF
}

cmd_status() {
    local state
    state="$(core_status)" || true
    echo "core:      $core_type"
    echo "status:    $state"
    echo "profile:   ${active_profile:-none}"
    echo "log_level: $log_level"
    echo "bind:      $bind_address"
    echo "mix_port:  $mix_port"
    if [ "$tun_mode" = "on" ]; then
        echo "tun:       on (stack: $tun_stack, device: $tun_device, mtu: $tun_mtu)"
    else
        echo "tun:       off"
    fi
    local rcount=0
    if [ -f "$RULES_FILE" ]; then
        rcount=$(grep -cv -e '^\s*$' -e '^#' "$RULES_FILE" 2>/dev/null) || rcount=0
    fi
    echo "rules:     $rcount custom"
    local gcount=0
    [ -d "$GEODATA_DIR" ] && gcount=$(find "$GEODATA_DIR" -maxdepth 1 -type f 2>/dev/null | wc -l)
    echo "geodata:   $gcount files"
}

cmd_config_show() {
    echo "# Network"
    echo "mix_port=$mix_port"
    echo "socks_port=$socks_port"
    echo "redir_port=$redir_port"
    echo "api_port=$api_port"
    echo "dns_port=$dns_port"
    echo "bind_address=$bind_address"
    echo ""
    echo "# Core"
    echo "core_type=$core_type"
    echo "log_level=$log_level"
    echo ""
    echo "# TUN"
    echo "tun_mode=$tun_mode"
    echo "tun_stack=$tun_stack"
    echo "tun_device=$tun_device"
    echo "tun_mtu=$tun_mtu"
    echo "tun_auto_route=$tun_auto_route"
    echo "tun_auto_detect=$tun_auto_detect"
    echo "tun_dns_hijack=$tun_dns_hijack"
    echo "tun_inet4=$tun_inet4"
    echo "tun_inet6=$tun_inet6"
    echo ""
    echo "# Profile"
    echo "active_profile=${active_profile:-}"
    echo "update_cron=${update_cron:-off}"
}

cmd_set() {
    local key="${1:-}" value="${2:-}"

    if [ -z "$key" ]; then
        echo "Usage: neocrash set <key> <value>" >&2
        echo "Run 'neocrash --help' to see available keys" >&2
        return 1
    fi

    # Handle cron specially
    if [ "$key" = "cron" ]; then
        if [ -z "$value" ]; then
            echo "Usage: neocrash set cron <schedule|off>" >&2
            return 1
        fi
        if [ "$value" = "off" ]; then
            cron_remove
            setconfig update_cron ""
            echo "Auto-update disabled"
        else
            cron_set_update "$value"
            echo "update_cron=$value"
        fi
        return 0
    fi

    if [ -z "$value" ]; then
        echo "Usage: neocrash set $key <value>" >&2
        return 1
    fi

    # Validate based on key
    case "$key" in
        mix_port|socks_port|redir_port|api_port|dns_port)
            if ! _validate_port "$value"; then
                echo "Error: invalid port '$value' (must be 1-65535)" >&2
                return 1
            fi
            ;;
        bind_address)
            ;;
        core_type)
            case "$value" in
                mihomo|singbox) ;;
                *) echo "Error: core_type must be 'mihomo' or 'singbox'" >&2; return 1 ;;
            esac
            ;;
        log_level)
            case "$value" in
                silent|error|warning|info|debug) ;;
                *) echo "Error: log_level must be silent|error|warning|info|debug" >&2; return 1 ;;
            esac
            ;;
        tun_mode)
            case "$value" in
                on|off) ;;
                *) echo "Error: tun_mode must be 'on' or 'off'" >&2; return 1 ;;
            esac
            ;;
        tun_stack)
            case "$value" in
                system|gvisor|mixed) ;;
                *) echo "Error: tun_stack must be 'system', 'gvisor', or 'mixed'" >&2; return 1 ;;
            esac
            ;;
        tun_auto_route|tun_auto_detect)
            case "$value" in
                true|false) ;;
                *) echo "Error: $key must be 'true' or 'false'" >&2; return 1 ;;
            esac
            ;;
        tun_mtu)
            if ! [[ "$value" =~ ^[0-9]+$ ]] || [ "$value" -lt 576 ] || [ "$value" -gt 65535 ]; then
                echo "Error: tun_mtu must be 576-65535" >&2
                return 1
            fi
            ;;
        tun_device|tun_dns_hijack|tun_inet4|tun_inet6)
            ;;
        *)
            echo "Error: unknown key '$key'" >&2
            echo "Run 'neocrash --help' to see available keys" >&2
            return 1
            ;;
    esac

    setconfig "$key" "$value"
    echo "$key=$value"
}

cmd_rule() {
    local subcmd="${1:-}"
    shift || true
    case "$subcmd" in
        add)
            local rule="${1:-}"
            if [ -z "$rule" ]; then
                echo "Usage: neocrash rule add <TYPE,value,action>" >&2
                echo "Example: neocrash rule add \"DOMAIN-SUFFIX,example.com,DIRECT\"" >&2
                return 1
            fi
            # Validate format: TYPE,value,action
            local rtype rvalue raction
            IFS=',' read -r rtype rvalue raction <<<"$rule"
            case "$rtype" in
                DOMAIN|DOMAIN-SUFFIX|DOMAIN-KEYWORD|IP-CIDR|GEOIP|GEOSITE) ;;
                *) echo "Error: unknown rule type '$rtype'" >&2
                   echo "Valid types: DOMAIN, DOMAIN-SUFFIX, DOMAIN-KEYWORD, IP-CIDR, GEOIP, GEOSITE" >&2
                   return 1 ;;
            esac
            if [ -z "$rvalue" ]; then
                echo "Error: rule value is required" >&2
                return 1
            fi
            if [ -z "$raction" ]; then
                echo "Error: rule action is required (e.g. DIRECT, REJECT, Proxy)" >&2
                return 1
            fi
            echo "$rule" >>"$RULES_FILE"
            echo "Rule added: $rule"
            ;;
        remove)
            local num="${1:-}"
            if [ -z "$num" ] || ! [[ "$num" =~ ^[0-9]+$ ]]; then
                echo "Usage: neocrash rule remove <line_number>" >&2
                return 1
            fi
            if [ ! -f "$RULES_FILE" ]; then
                echo "Error: no rules file" >&2
                return 1
            fi
            local total
            total=$(wc -l <"$RULES_FILE")
            if [ "$num" -lt 1 ] || [ "$num" -gt "$total" ]; then
                echo "Error: line $num out of range (1-$total)" >&2
                return 1
            fi
            local removed
            removed=$(sed -n "${num}p" "$RULES_FILE")
            sed -i "${num}d" "$RULES_FILE"
            echo "Removed: $removed"
            ;;
        list)
            if [ ! -f "$RULES_FILE" ] || [ ! -s "$RULES_FILE" ]; then
                echo "No custom rules"
                return 0
            fi
            local i=1
            while IFS= read -r line; do
                echo "  $i) $line"
                i=$((i + 1))
            done <"$RULES_FILE"
            ;;
        *)
            echo "Usage: neocrash rule <add|remove|list> [args]" >&2
            return 1
            ;;
    esac
}

cmd_geodata() {
    local subcmd="${1:-}"
    shift || true
    case "$subcmd" in
        list)       geodata_list ;;
        available)  geodata_available ;;
        update)
            if [ "${1:-}" = "all" ] || [ "${1:-}" = "-all" ]; then
                geodata_update_all
            else
                geodata_update "${1:-}"
            fi
            ;;
        update-all) geodata_update_all ;;
        remove)     geodata_remove "${1:-}" ;;
        import)     geodata_import "${1:-}" ;;
        *)
            echo "Usage: neocrash geodata <list|available|update|update-all|remove|import> [args]" >&2
            return 1
            ;;
    esac
}

cmd_profile() {
    local subcmd="${1:-}"
    shift || true
    case "$subcmd" in
        list)       profile_list || echo "No profiles found" ;;
        add)        profile_add "${1:-}" "${2:-}" ;;
        import)     profile_import "${1:-}" "${2:-}" ;;
        remove)     profile_remove "${1:-}" ;;
        switch)     profile_switch "${1:-}" ;;
        update)     profile_update "${1:-}" ;;
        update-all) profile_update_all ;;
        *)
            echo "Usage: neocrash profile <list|add|import|remove|switch|update|update-all> [args]" >&2
            return 1
            ;;
    esac
}

# Main dispatch
case "${1:-}" in
    start)      core_start ;;
    stop)       core_stop; echo "Stopped" ;;
    restart)    core_restart ;;
    status)     cmd_status ;;
    profile)    shift; cmd_profile "$@" ;;
    geodata)    shift; cmd_geodata "$@" ;;
    rule)       shift; cmd_rule "$@" ;;
    set)        shift; cmd_set "$@" ;;
    config)
        case "${2:-}" in
            show) cmd_config_show ;;
            *) echo "Usage: neocrash config show" >&2; exit 1 ;;
        esac
        ;;
    update)     profile_update "${2:-}" ;;
    version)    echo "neocrash $VERSION" ;;
    -h|--help)  usage ;;
    "")         usage ;;
    *)
        echo "Unknown command: $1" >&2
        echo "Run 'neocrash --help' for usage" >&2
        exit 1
        ;;
esac
